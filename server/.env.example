# Copy this file to server/.env and replace every placeholder locally.
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
DATABASE_URL="mysql://gearflow_user:replace_password@127.0.0.1:3306/gearflow"
DEMO_EMAIL=demo@gearflow.app
DEMO_PASSWORD=ride123
SESSION_SECRET=replace-with-a-long-random-string
# Reserved for deployments that add JWT-based integrations; the current app uses SESSION_SECRET.
JWT_SECRET=replace-with-a-long-random-string
ORS_API_KEY=replace-with-your-openrouteservice-api-key
COOKIE_SECURE=false
